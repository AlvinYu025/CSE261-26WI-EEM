    "        random_state=42, n_jobs=-1, verbosity=0\n",
    "    ),\n",
    "    'LightGBM': LGBMRegressor(\n",
    "        n_estimators=300, learning_rate=0.05, max_depth=6,\n",
    "        subsample=0.8, colsample_bytree=0.8,\n",
    "        random_state=42, n_jobs=-1, verbose=-1\n",
    "    )\n",
    "}"
   ]
